            },
            {
                "name": "岑参",
                "year": 750,
                "title": "鼓吹曲辞 凯歌六首 五",
                "poem": [
                    "蕃军遥见汉家营，满谷连山徧哭声。",
                    "万箭千刀一夜杀，平明流血浸空城。"
                ],
                "style": "悲壮挽歌",
